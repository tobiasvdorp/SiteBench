{
  "name": "@sitebench/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "sitebench": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "NODE_OPTIONS='--experimental-sqlite' tsx src/index.ts",
    "test": "NODE_OPTIONS='--experimental-sqlite' vitest run"
  },
  "dependencies": {
    "@sitebench/core": "workspace:*",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
