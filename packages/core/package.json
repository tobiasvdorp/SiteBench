{
  "name": "@sitebench/core",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./histogram": {
      "types": "./dist/histogram.d.ts",
      "import": "./dist/histogram.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "NODE_OPTIONS='--experimental-sqlite' vitest run",
    "test:watch": "NODE_OPTIONS='--experimental-sqlite' vitest"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "robots-parser": "^3.0.1",
    "undici": "^7.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
